# Copia este archivo como .env y completa la clave para habilitar /api/chat.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Orígenes separados por coma desde los que el frontend puede llamar a la API.
CORS_ORIGINS=http://localhost:3000

# SQLite solo guarda el historial simple de las sesiones de chat.
DATABASE_URL=sqlite:///./portoasiste.db
FAISS_INDEX_DIR=./faiss_index
GENERATED_PDFS_DIR=./generated_pdfs
