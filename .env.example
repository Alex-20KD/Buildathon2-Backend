# Copia este archivo como .env y completa la clave para habilitar /api/chat.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Orígenes separados por coma desde los que el frontend puede llamar a la API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://buildathon2-frontend.vercel.app

# Persistencia del historial de chat. Para desarrollo local se usa SQLite.
DATABASE_URL=sqlite:///./portoasiste.db

# Producción: Supabase PostgreSQL (usa la contraseña real del proyecto, no este texto).
# Si la contraseña contiene caracteres especiales como @, :, /, ?, # o %, codifícala
# como URL antes de incluirla. Ejemplo: @ se escribe %40.
# DATABASE_URL=postgresql://postgres:TU_CONTRASENA@db.lrhpnfcroynmaepxoglz.supabase.co:5432/postgres
FAISS_INDEX_DIR=./faiss_index
GENERATED_PDFS_DIR=./generated_pdfs
